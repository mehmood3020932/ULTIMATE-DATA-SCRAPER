{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "JobEvent": {
      "type": "object",
      "required": ["event_type", "job_id", "timestamp"],
      "properties": {
        "event_type": {
          "type": "string",
          "enum": ["started", "progress", "agent_started", "agent_completed", "error", "completed"]
        },
        "job_id": {"type": "string"},
        "severity": {
          "type": "string",
          "enum": ["debug", "info", "warning", "error", "critical"]
        },
        "message": {"type": "string"},
        "agent_name": {"type": "string"},
        "metadata": {"type": "object"},
        "timestamp": {"type": "string", "format": "date-time"}
      }
    }
  }
}